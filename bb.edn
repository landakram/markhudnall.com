{:min-bb-version "0.4.0"
 :tasks
 {build (shell "npm" "run" "build")
  build:css (shell "npm" "run" "build:css")
  build:js (shell "npm" "run" "build:js")
  export (shell "npm" "run" "export")
  serve (shell "python3" "-m" "http.server" "--directory" "dist/" "3001")
  dev:js (shell "npm" "run" "dev:js")
  dev:css (shell "npm" "run" "dev:css")
  deploy (shell "git" "push" "dokku" "master")}}
